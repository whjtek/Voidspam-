-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    -- Auto target
    if not TargetPlayer or not TargetPlayer.Character then
        local closest, dist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local d = (plr.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = plr
                end
            end
        end
        TargetPlayer = closest
    end

    if VoidSpamEnabled and TargetPlayer and TargetPlayer.Character then
        local hrp = char.HumanoidRootPart
        local thrp = TargetPlayer.Character.HumanoidRootPart
        local dir = (hrp.Position - thrp.Position).Unit
        hrp.CFrame = thrp.CFrame + dir * Settings.VoidMaxDistance * 0.7 + Vector3.new(math.random(-10,10), math.random(8,20), math.random(-10,10))
    end

    if AttackEnabled and TargetPlayer and TargetPlayer.Character then
        local hrp = char.HumanoidRootPart
        local thrp = TargetPlayer.Character.HumanoidRootPart
        hrp.CFrame = thrp.CFrame + (hrp.Position - thrp.Position).Unit * Settings.AttackStandDistance
    end
end)
