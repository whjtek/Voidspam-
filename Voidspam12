local function createToggle(text, default, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95,0,0,55)
    btn.BackgroundColor3 = default and Color3.fromRGB(0,170,90) or Color3.fromRGB(55,55,80)
    btn.Text = text .. ": " .. (default and "ON" or "OFF")
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 16
    btn.Parent = voidTab
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)

    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0,170,90) or Color3.fromRGB(55,55,80)
        btn.Text = text .. ": " .. (state and "ON" or "OFF")
        callback(state)
    end)
end

createToggle("Void Spam", false, function(v) VoidSpamEnabled = v end)
