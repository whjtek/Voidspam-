-- ==================== FUNCTIONS ====================
local function getClosestPlayer()
    local closest, dist = nil, math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local d = (plr.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist = d
                closest = plr
            end
        end
    end
    return closest
end

local function voidSpam()
    if not VoidSpamEnabled or not TargetPlayer or not TargetPlayer.Character then return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHrp = TargetPlayer.Character.HumanoidRootPart
    if not hrp then return end

    local dir = (hrp.Position - targetHrp.Position).Unit
    local randomOffset = Vector3.new(math.random(-8,8), math.random(4,12), math.random(-8,8))
    
    hrp.CFrame = targetHrp.CFrame + dir * Settings.VoidSpamDistance + randomOffset
end

local function orbitAttack()
    if not OrbitAttackEnabled or not TargetPlayer or not TargetPlayer.Character then return end
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local targetHrp = TargetPlayer.Character.HumanoidRootPart
    if not hrp then return end

    orbitAngle += Settings.OrbitSpeed * 0.016
    local offset = Vector3.new(
        math.cos(orbitAngle) * Settings.OrbitRadius,
        5,
        math.sin(orbitAngle) * Settings.OrbitRadius
    )
    
    hrp.CFrame = CFrame.new(targetHrp.Position + offset, targetHrp.Position)
end

