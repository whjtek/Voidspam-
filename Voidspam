distanceLabel.Parent = infoContent

-- Main Loop
RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end

    -- Auto target nearest if none selected
    if not TargetPlayer or not TargetPlayer.Character then
        TargetPlayer = getClosestPlayer()
    end

    -- Void Spam
    if VoidSpamEnabled and tick() - lastSpam > Settings.SpamRate then
        voidSpam()
        lastSpam = tick()
    end

    -- Orbit Attack
    if OrbitAttackEnabled then
        orbitAttack()
    end

    -- Update Distance Label
    if TargetPlayer and TargetPlayer.Character then
        local dist = (TargetPlayer.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
        distanceLabel.Text = "Target: " .. TargetPlayer.Name .. "\nDistance: " .. math.floor(dist) .. " studs"
    else
        distanceLabel.Text = "Target: None\nDistance: 0 studs"
    end
end)

