-- Void Spam Tab
local function addToggle(parent, text, default, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -20, 0, 45)
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(50,50,70)
    btn.Text = text .. ": " .. (default and "ON" or "OFF")
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 16
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,10)
    
    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0, 170, 100) or Color3.fromRGB(50,50,70)
        btn.Text = text .. ": " .. (state and "ON" or "OFF")
        callback(state)
    end)
end

addToggle(voidContent, "Void Spam", false, function(v) VoidSpamEnabled = v end)

-- Orbit Attack
addToggle(orbitContent, "Orbit Attack", false, function(v) OrbitAttackEnabled = v end)

-- Settings Sliders
local function addSlider(parent, label, min, max, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -20, 0, 50)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(0.5,0,0.5,0)
    lbl.Text = label
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.BackgroundTransparency = 1
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 15

    local val = Instance.new("TextLabel", frame)
    val.Size = UDim2.new(0.5,0,0.5,0)
    val.Position = UDim2.new(0.5,0,0,0)
    val.Text = default
    val.TextColor3 = Color3.new(1,1,1)
    val.BackgroundTransparency = 1

    -- Simple slider (you can expand later)
    local slider = Instance.new("TextButton", frame)
    slider.Size = UDim2.new(1,0,0.5,0)
    slider.Position = UDim2.new(0,0,0.5,0)
    slider.BackgroundColor3 = Color3.fromRGB(70,0,150)
    slider.Text = ""
    Instance.new("UICorner", slider).CornerRadius = UDim.new(0,8)

    slider.MouseButton1Click:Connect(function()
        local newVal = tonumber(prompt("Enter value for " .. label, default)) or default
        newVal = math.clamp(newVal, min, max)
        val.Text = newVal
        callback(newVal)
    end)
end

addSlider(voidContent, "Void Spam Distance", 5, 50, 15, function(v) Settings.VoidSpamDistance = v end)
addSlider(orbitContent, "Orbit Radius", 4, 20, 8, function(v) Settings.OrbitRadius = v end)
