-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function(dt)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    -- Auto Target with checks
    if not TargetPlayer or not TargetPlayer.Character then
        local closest, dist = nil, math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local root = plr.Character:FindFirstChild("HumanoidRootPart")
                local hum = plr.Character:FindFirstChildOfClass("Humanoid")
                if root and hum then
                    if Settings.DeadCheck and hum.Health <= 0 then continue end
                    if Settings.TeamCheck and plr.Team == LocalPlayer.Team then continue end

                    local d = (root.Position - char.HumanoidRootPart.Position).Magnitude
                    if d < dist then
                        dist = d
                        closest = plr
                    end
                end
            end
        end
        TargetPlayer = closest
    end

    -- Void Spam
    if VoidSpamEnabled and TargetPlayer and TargetPlayer.Character and tick() - lastSpam > Settings.SpamRate then
        local hrp = char.HumanoidRootPart
        local thrp = TargetPlayer.Character.HumanoidRootPart
        local dir = (hrp.Position - thrp.Position).Unit
        hrp.CFrame = thrp.CFrame + dir * Settings.VoidSpamDistance + Vector3.new(math.random(-15,15), math.random(10,25), math.random(-15,15))
        lastSpam = tick()
    end

    -- Attack Orbit
    if AttackEnabled and TargetPlayer and TargetPlayer.Character then
        local hrp = char.HumanoidRootPart
        local thrp = TargetPlayer.Character.HumanoidRootPart
        orbitAngle += Settings.OrbitSpeed * dt * 0.4
        local offset = Vector3.new(math.cos(orbitAngle) * Settings.OrbitRadius, 6, math.sin(orbitAngle) * Settings.OrbitRadius)
        hrp.CFrame = CFrame.new(thrp.Position + offset, thrp.Position)
    end

    -- Update Distance Panel
    if TargetPlayer and TargetPlayer.Character then
        local dist = (TargetPlayer.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
        distanceLabel.Text = "Target: " .. TargetPlayer.Name .. "\nDistance: " .. math.floor(dist) .. " studs"
    else
        distanceLabel.Text = "No Target\nDistance: 0 studs"
    end
end)

