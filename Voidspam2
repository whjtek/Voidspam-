-- ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function(dt)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    if not TargetPlayer or not TargetPlayer.Character then
        -- Auto target nearest player
        local closestDist = math.huge
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local d = (plr.Character.HumanoidRootPart.Position - char.HumanoidRootPart.Position).Magnitude
                if d < closestDist then
                    closestDist = d
                    TargetPlayer = plr
                end
            end
        end
    end

    -- Void Spam
    if VoidSpamEnabled and TargetPlayer and TargetPlayer.Character and tick() - lastSpam > Settings.SpamRate then
        local hrp = char.HumanoidRootPart
        local targetHrp = TargetPlayer.Character.HumanoidRootPart
        local dir = (hrp.Position - targetHrp.Position).Unit
        hrp.CFrame = targetHrp.CFrame + dir * Settings.VoidSpamDistance + Vector3.new(math.random(-6,6), math.random(6,14), math.random(-6,6))
        lastSpam = tick()
    end

    -- Orbit Attack
    if OrbitAttackEnabled and TargetPlayer and TargetPlayer.Character then
        local hrp = char.HumanoidRootPart
        local targetHrp = TargetPlayer.Character.HumanoidRootPart
        orbitAngle += Settings.OrbitSpeed * dt * 8
        local offset = Vector3.new(math.cos(orbitAngle) * Settings.OrbitRadius, 6, math.sin(orbitAngle) * Settings.OrbitRadius)
        hrp.CFrame = CFrame.new(targetHrp.Position + offset, targetHrp.Position)
    end
end)

