local contents = {}

local function switchTab(name)
    for _, v in pairs(contents) do v.Visible = false end
    if contents[name] then contents[name].Visible = true end
end

local function createTab(name, x)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.25,-5,1,0)
    btn.Position = UDim2.new(x,0,0,0)
    btn.BackgroundColor3 = Color3.fromRGB(35,35,60)
    btn.Text = name
