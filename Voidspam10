-- Toggle & Slider
local function createToggle(parent, text, default, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95,0,0,52)
    btn.BackgroundColor3 = default and Color3.fromRGB(0,180,90) or Color3.fromRGB(55,55,80)
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 16
    btn.Parent = parent
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0,180,90) or Color3.fromRGB(55,55,80)
        callback(state)
    end)
end

local function createSlider(parent, label, min, max, default, step, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.95,0,0,70)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local lbl = Instance.new("TextLabel", frame)
    lbl.Size = UDim2.new(1,0,0,22)
    lbl.Text = label .. ": " .. default
    lbl.TextColor3 = Color3.new(1,1,1)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 15

    local bar = Instance.new("Frame", frame)
    bar.Size = UDim2.new(1,0,0,14)
    bar.Position = UDim2.new(0,0,0,32)
    bar.BackgroundColor3 = Color3.fromRGB(40,40,65)
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,6)

    local fill = Instance.new("Frame", bar)
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(100,200,255)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0,6)

    local dragging = false
    bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end end)

    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        local perc = math.clamp((i.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local val = min + perc * (max - min)
        if step then val = math.floor(val / step) * step end
        fill.Size = UDim2.new((val-min)/(max-min),0,1,0)
        lbl.Text = label .. ": " .. val
        callback(val)
    end)
end

