    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 15
    btn.Parent = tabFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1,0,1,-110)
    content.Position = UDim2.new(0,0,0,110)
