local contents = {}

local function switchTab(name)
    for _, v in pairs(contents) do v.Visible = false end
    if contents[name] then contents[name].Visible = true end
end

local function createTab(name, xPos)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.25,-5,1,0)
    btn.Position = UDim2.new(xPos,2,0,0)
    btn.BackgroundColor3 = Color3.fromRGB(30,30,50)
    btn.Text = name
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextSize = 15
    btn.Parent = tabFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1,0,1,-115)
    content.Position = UDim2.new(0,0,0,115)
    content.BackgroundTransparency = 1
    content.ScrollBarThickness = 5
    content.Visible = false
    content.Parent = mainFrame

    Instance.new("UIListLayout", content).Padding = UDim.new(0,8)
    
    contents[name] = content
    btn.MouseButton1Click:Connect(function() switchTab(name) end)
    return content
end

